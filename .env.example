# Proxmox VE Credentials
# Copy this file to .env and fill in your Proxmox server details

# Proxmox server hostname or IP address (with optional port, e.g., proxmox.example.com:8006)
PROXMOX_HOST=proxmox.example.com

# API Token ID in format: user@realm!tokenid (e.g., portal@pam!portal)
# Created in Proxmox web UI: Datacenter > Permissions > API Tokens
PROXMOX_TOKEN_ID=user@realm!tokenid

# API Token Secret (shown only once when token is created)
PROXMOX_TOKEN_SECRET=your-token-secret

# Azure Credentials 
AZURE_CLIENT_ID=client-id
AZURE_CLIENT_SECRET=client-secret
AZURE_TENANT_ID=tenant-id
AZURE_SUBSCRIPTION_ID=subscription-id

# AWS Credentials
AWS_ACCESS_KEY_ID=aws-access-id
AWS_SECRET_ACCESS_KEY=aws-secret-key
AWS_REGION=us-east-1
#AWS_SESSION_TOKEN= # OPTIONAL

# Labs — GitHub Actions integration
# Personal access token with repo + workflow scopes
GITHUB_TOKEN=ghp_your_token_here
# Directory where lab repos are cloned (relative to pve-backend)
LABS_DIR=./labs_repos

# ValueIron DNS — authoritative DNS management
# Base URL of the valueiron_dns Go API
VALUEIRON_DNS_URL=http://localhost:8080
# API key (leave empty if auth is disabled in valueiron_dns)
VALUEIRON_DNS_API_KEY=

# SSH terminal (browser shell to lab VMs)
SSH_USERNAME=your-ssh-username
# Path to SSH private key (e.g. /run/secrets/id_rsa in Docker, ~/.ssh/id_rsa locally)
SSH_PRIVATE_KEY_PATH=
SSH_PORT=22
